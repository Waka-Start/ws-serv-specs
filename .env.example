# ──────────────────────────────────────────────────────────────────
# WS-SERV-SPECS — Service de gestion des specifications WakaSpecs
# Port : 3014
# ──────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────
# SERVEUR
# ──────────────────────────────────────────────────────────────────

PORT=3014
NODE_ENV=development
DEBUG=false

# ──────────────────────────────────────────────────────────────────
# BASE DE DONNEES POSTGRESQL (PRISMA)
# Base dediee au service specs (separee de ws-serv-config)
# ──────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://admin:admin@localhost:5432/specs?schema=public"
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ──────────────────────────────────────────────────────────────────
# SECURITE INTER-SERVICES
# ──────────────────────────────────────────────────────────────────

# Cle API pour l'authentification S2S via x-api-key
# Format: min 32 chars ASCII
# Obligatoire: oui en production
API_KEY=changeme_must_be_at_least_32_characters_long

# ──────────────────────────────────────────────────────────────────
# IA — ANTHROPIC (CLAUDE)
# Cle API pour la redaction assistee par IA
# ──────────────────────────────────────────────────────────────────

# Cle API Anthropic pour les appels Claude
# Format: sk-ant-api03-...
# Obligatoire: oui (necessaire pour la ventilation, generation, modification de contenu)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Modele Claude a utiliser pour la generation (taches complexes)
# Valeurs: claude-sonnet-4-20250514, claude-opus-4-20250514
# Defaut: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Modele Claude leger pour les taches non-critiques (suggestions, evaluations, classifications)
# Defaut: claude-haiku-4-5-20251001
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001

# Modele avance pour les taches critiques (optionnel, fallback sur ANTHROPIC_MODEL)
# Valeurs: claude-opus-4-20250514
# ANTHROPIC_MODEL_ADVANCED=claude-opus-4-20250514

# ──────────────────────────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────────────────────────

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004,http://localhost:3009
CORS_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_HEADERS=Content-Type,Authorization,x-api-key,x-user-keycloak-id,x-user-email,x-user-admin-level,x-user-partner-wid
CORS_CREDENTIALS=true

# ──────────────────────────────────────────────────────────────────
# VALKEY (BullMQ — convention WakaStart : VALKEY_*)
# ──────────────────────────────────────────────────────────────────

VALKEY_HOST=localhost
VALKEY_PORT=6379
# Optionnels — requis si Valkey du cluster a AUTH/TLS activés
# VALKEY_USERNAME=
# VALKEY_PASSWORD=
# VALKEY_TLS=false

# ──────────────────────────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────────────────────────

THROTTLE_TTL=60000
THROTTLE_LIMIT=500
